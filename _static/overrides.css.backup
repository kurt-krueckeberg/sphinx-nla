/* =========================================== */
/* Settings for a softer deark mode like mystmd.org
/* ============================================ */

/* soften the overall dark page */
/* TODO: Fix this: dark mode does not work with the default font colors */	
html[data-theme="dark"] {
  --pst-color-background: #201b18;
  --pst-color-on-background: #e8e1d9;
}

/* page body / main surfaces */
html[data-theme="dark"] body {
  background-color: #201b18;
  color: #e8e1d9;
}

html[data-theme="dark"] .bd-main {
  background-color: #201b18;
}

/* top banner / header */
html[data-theme="dark"] .bd-header {
  background-color: #332822 !important;
  border-bottom: 1px solid #4a3a31;
}

/* optional: sidebar a little different from the main page */
html[data-theme="dark"] .bd-sidebar,
html[data-theme="dark"] .bd-sidebar-primary,
html[data-theme="dark"] .bd-sidebar-secondary {
  background-color: #261f1b;
}

/* links in dark mode */
html[data-theme="dark"] a {
  color: #d7b07a;
}

html[data-theme="dark"] a:hover {
  color: #efc58f;
}
