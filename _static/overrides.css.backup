/* creates a shadow-obrder for images */
img.image-override,
.image-override img {
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.20);
  border-radius: 4px;
  background: white;
  padding: 6px;
  max-width: 100%;
  height: auto;
  cursor: zoom-in;
}

@media (prefers-color-scheme: dark) {
  img.image-override,
  .image-override img {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.10),
      0 6px 16px rgba(0, 0, 0, 0.55);
    background: #1f1f1f;
    cursor: zoom-in;
  }
}

/* =========================================================================
   Five Optional palette blocks for sphinx_book_theme and pydata_sphinx_theme.
   ========================================================================== */

/* 1) scikit-learn (direct) */
/*
html[data-theme="light"] {
  --pst-color-primary: #29abe2;
  --pst-color-secondary: #f7931e;
}
html[data-theme="dark"] {
  --pst-color-primary: #64bce9;
  --pst-color-secondary: #f99f44;
}
*/

/* Set the active color palette */
html[data-theme="light"] {
  --pst-color-primary: #276be9;
  --pst-color-secondary: var(--pst-color-warning);
}

html[data-theme="dark"] {
  --pst-color-primary: #79a3f2;
  --pst-color-secondary: var(--pst-color-warning);
}

