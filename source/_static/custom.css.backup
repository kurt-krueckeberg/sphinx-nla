/* --- source/_static/custom.css --- */

:root {
    /* Standard is ~60em. This gives your transliterations 
       and tables much more room to breathe. */
    --pst-content-width: 90em; 

    /* Ensures the sidebar is wide enough for your 
       numeric module names (e.g., 2728, rentkammer) */
    --pst-sidebar-width: 18em;
}

/* 1. The "Extra Wide" Override */
/* This allows the main content container to use up to 95% 
   of your browser window on large monitors. */
.bd-main .bd-content {
    max-width: 95% !important;
}

/* 2. Remove the Article Cap */
/* Some themes hard-cap the text width; this removes that restriction. */
article.bd-article {
    max-width: none !important;
}

/* 3. Image Flexibility */
/* This ensures that high-res scans scale to the 
   container width without overflowing or distorting. */
img {
    max-width: 100%;
    height: auto;
}
